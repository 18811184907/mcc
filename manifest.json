{
  "$schema": "https://schemas.mcc.dev/manifest-v1.json",
  "name": "mcc",
  "version": "1.1.0",
  "description": "Multi-target Claude/Codex Configuration",
  "license": "MIT",
  "homepage": "https://github.com/18811184907/mcc",

  "targets": {
    "claude-code": {
      "label": "Claude Code",
      "dist_dir": "dist/claude-code",
      "install_global": "~/.claude",
      "install_project": ".claude",
      "settings_fragment": "dist/claude-code/.claude/settings.fragment.json",
      "mcp_config": "dist/claude-code/.claude/mcp-configs/mcp.json",
      "hooks_config": "dist/claude-code/.claude/.mcc-hooks/hooks.json",
      "hooks_scripts_dir": "dist/claude-code/.claude/.mcc-hooks/scripts",
      "detect": [
        {"kind": "file_exists", "path": "~/.claude/settings.json"},
        {"kind": "env", "name": "CLAUDE_CODE_HOME"}
      ]
    },
    "codex": {
      "label": "Codex",
      "dist_dir": "dist/codex",
      "install_global": "~/.codex",
      "install_project": ".codex",
      "agents_md": "dist/codex/AGENTS.md",
      "config_fragment": "dist/codex/config.fragment.toml",
      "hooks_soft_guidance": "dist/codex/HOOKS-SOFT-GUIDANCE.md",
      "detect": [
        {"kind": "file_exists", "path": "~/.codex/config.toml"},
        {"kind": "file_exists", "path": "~/.codex/"},
        {"kind": "env", "name": "CODEX_HOME"}
      ]
    }
  },

  "components": {
    "agents": 19,
    "commands": 20,
    "skills": 16,
    "modes": 3,
    "hooks": 8,
    "hook_scripts": 25,
    "mcp_servers": 5,
    "rules_python": 5,
    "rules_common": 1,
    "principles_sections": 6
  },

  "compatibility": {
    "claude_code_min_version": "2.1.0",
    "node_min_version": "18.0.0",
    "platforms": ["windows", "macos", "linux"]
  },

  "merge_strategy": {
    "agents": "skip_existing",
    "commands": "skip_existing",
    "skills": "skip_existing_dir",
    "modes": "skip_existing",
    "rules": "skip_existing",
    "hook_scripts": "replace_in_mcc_namespace",
    "settings_json": "deep_merge_with_dedup",
    "config_toml": "append_sections_dedup",
    "PRPs_directory": "create_only_missing"
  },

  "install_variables": {
    "MCC_HOOKS": {
      "description": "hooks 脚本的真实安装位置",
      "resolved_at_install": true
    },
    "MCC_SKILLS": {
      "description": "skills 的真实安装位置",
      "resolved_at_install": true
    },
    "MCC_HOME": {
      "description": "MCC 安装根目录（随 scope 决定是 ~/.claude/.mcc-hooks 或 项目/.claude/.mcc-hooks）",
      "resolved_at_install": true
    }
  },

  "uninstall": {
    "strategy": "restore_from_backup",
    "backup_dir_pattern": "{home}/.claude.backup-{timestamp}",
    "preserve": [
      "PRPs/**/*.md",
      "session-data/*",
      "skills/learned/*",
      "docs/mistakes/*",
      "docs/adr/*"
    ],
    "note": "卸载只恢复 MCC 装之前的配置文件；用户工作产物（PRD/plan/report/session/learned skill）一律保留"
  },

  "build": {
    "source_dir": "source/",
    "adapters_dir": "adapters/",
    "dist_dir": "dist/",
    "build_command": "node adapters/build.js"
  },

  "version_history": [
    {
      "version": "1.1.0",
      "date": "2026-04-24",
      "changes": [
        "v1.1 增量：纳入 obra/superpowers 的 8 个 skill（去源 + 中文化 + 融入 MCC 生态）",
        "新增 subagent-driven-development skill：每任务 fresh subagent + 两阶段 review（spec → quality）",
        "新增 tdd-workflow skill（原 test-driven-development 改名）：填补 v1.0 /mcc:tdd 的 skill 实现体，含 testing-anti-patterns",
        "新增 writing-skills：创作 skill 的 meta-skill，含 Anthropic 官方最佳实践参考资料",
        "新增 using-git-worktrees：worktree 隔离并行开发",
        "新增 finishing-a-development-branch：分支收尾（merge/PR/cleanup）",
        "新增 requesting-code-review + receiving-code-review：代码审查两端流程",
        "新增 dispatching-parallel-agents：独立任务并行分发（和 party-mode 辩论互补）",
        "skills 从 8 扩展到 16",
        "LICENSE 加 obra/superpowers 第 5 源 attribution"
      ]
    },
    {
      "version": "1.0.0",
      "date": "2026-04-24",
      "changes": [
        "初始版本",
        "19 agents（含 5 个融合型：code-reviewer / debugger / backend-architect / database-optimizer / performance-engineer）",
        "20 commands（PRP 流水线 + full-stack 大流水线 + 诊断三档 + 测试三路）",
        "8 skills（含 mcc-help 的 workflow-map.json 扫 fs 推进度）",
        "3 Behavioral Modes（brainstorming/task-management/token-efficiency）",
        "8 hooks（pre:config-protection 是独家）",
        "5 MCPs（Serena/Context7/GitHub/Sequential/Playwright）",
        "Python rules 5 个 + mcc-principles.md（SC PRINCIPLES 中文化融合）",
        "双目标 adapter（claude-code + codex），0.2 秒构建"
      ]
    }
  ],

  "roadmap": [
    {
      "version": "1.2.0",
      "planned": true,
      "theme": "按社区反馈扩展",
      "items": [
        "根据用户使用反馈补齐缺失 skill/command",
        "可能加入更多语言 rules（Go / Rust）",
        "可能支持 Cursor / Gemini CLI 作为第三/第四目标",
        "加入 MCC 自检测试套件"
      ]
    }
  ]
}
