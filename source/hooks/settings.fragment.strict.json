{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_mcc_fragment_note": "v2.3+ 严格模式（installer --strict 启用）：细粒度白名单 + askForPermission，每次新工具调用弹窗确认。适合企业 / 安全敏感场景。默认信任模式见 settings.fragment.json。",

  "permissions": {
    "allow": [
      "Read(*)",
      "Grep(*)",
      "Glob(*)",
      "Write(*.md)",
      "Edit(*.md)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(npm *)",
      "Bash(pnpm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(uv *)",
      "Bash(uvx *)",
      "Bash(pip *)",
      "Bash(python *)",
      "Bash(pytest *)",
      "Bash(ruff *)",
      "Bash(mypy *)",
      "Bash(pyright *)",
      "Bash(black *)",
      "Bash(prettier *)",
      "Bash(biome *)",
      "Bash(eslint *)",
      "Bash(tsc *)",
      "Bash(playwright *)",
      "WebFetch(*)"
    ],
    "deny": [],
    "ask": []
  },

  "enableAllProjectMcpServers": true,

  "_mcc_v2_6_4_strict_now_includes_vault_hooks": "v2.6.4 fix (codex audit HIGH): strict 之前缺 vault hooks，安全敏感用户选 strict 反而失去 secret 防护。现在 strict 也装 pre-vault-leak-detect / post-vault-sync / post-user-vault-sync（这些是安全核心，跟 strict 哲学一致）。",

  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${MCC_HOOKS}/hooks/session-start-bootstrap.js",
            "timeout": 5
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node ${MCC_HOOKS}/hooks/pre-vault-leak-detect.js",
            "async": false,
            "timeout": 3
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${MCC_HOOKS}/hooks/post-vault-sync.js",
            "async": false,
            "timeout": 5
          },
          {
            "type": "command",
            "command": "node ${MCC_HOOKS}/hooks/post-user-vault-sync.js",
            "async": false,
            "timeout": 5
          }
        ]
      }
    ],

    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "node -e \"require('${MCC_HOOKS}/hooks/session-end.js').run(process.stdin)\"",
            "async": true,
            "timeout": 10
          },
          {
            "type": "command",
            "command": "node -e \"require('${MCC_HOOKS}/hooks/check-console-log.js').run(process.stdin)\"",
            "async": true,
            "timeout": 5
          }
        ]
      }
    ]
  }
}
